{
  "name": "@trovyhq/mcp-server",
  "version": "1.0.3",
  "description": "Model Context Protocol server for Trovy \u2014 drive Trovy from Claude Desktop, Cursor, or any MCP-aware AI client.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "trovy-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:pack": "npm run build && node scripts/smoke-install.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build && npm run smoke:pack"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "trovy",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude",
    "taskflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trovyhq/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/trovyhq/mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trovyhq/sdk": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "typescript": "^5.6.2"
  }
}
